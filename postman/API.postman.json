    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "  if (data[0].id) pm.environment.set('category_id', data[0].id);",
                  "  if (data[0].slug) pm.environment.set('category_slug', data[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/products/categories/"
          }
        },
        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const items = Array.isArray(data) ? data : (data.results || []);",
                  "if (items.length > 0) {",
                  "  if (items[0].id) pm.environment.set('product_id', items[0].id);",
                  "  if (items[0].slug) pm.environment.set('product_slug', items[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/products/"
          }
        },
        {
          "name": "Product Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/products/{{product_slug}}/"
          }
        }
      ]
    },
    {
      "name": "Seller",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) pm.environment.set('product_id', data.id);",
                  "if (data.slug) pm.environment.set('product_slug', data.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRFToken", "value": "{{csrftoken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": \"{{category_id}}\",\n  \"title\": \"Postman Product\",\n  \"slug\": \"postman-product\",\n  \"short_description\": \"Short description\",\n  \"full_description\": \"Full description from Postman.\",\n  \"product_type\": \"template\",\n  \"base_price\": \"29.99\",\n  \"currency\": \"USD\"\n}"
            },
            "url": "{{base_url}}/api/v1/seller/products/"
          }
        },
        {
          "name": "Add Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRFToken", "value": "{{csrftoken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"image_url\": \"https://example.com/postman-cover.jpg\",\n  \"alt_text\": \"Postman cover\",\n  \"sort_order\": 0,\n  \"is_cover\": true\n}"
            },
            "url": "{{base_url}}/api/v1/seller/products/{{product_id}}/images/"
          }
        },
        {
          "name": "Add File",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRFToken", "value": "{{csrftoken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file_name\": \"postman-product.zip\",\n  \"storage_key\": \"products/postman-product.zip\",\n  \"mime_type\": \"application/zip\",\n  \"file_size\": 2048,\n  \"checksum\": \"checksum-postman-001\"\n}"
            },
            "url": "{{base_url}}/api/v1/seller/products/{{product_id}}/files/"
          }
        },
