          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.download_url) {",
                  "  const token = data.download_url.split('/').filter(Boolean).pop();",
                  "  pm.environment.set('download_token', token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/library/{{product_id}}/download/"
